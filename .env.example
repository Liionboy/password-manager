# JWT Configuration
JWT_SECRET=__PUNE_AICI_JWT_SECRET__
JWT_EXPIRY=15m
REFRESH_SECRET=__PUNE_AICI_REFRESH_SECRET__
REFRESH_EXPIRY=7d

# Encryption - MUST be exactly 32 characters for AES-256
ENCRYPTION_KEY=__PUNE_AICI_ENCRYPTION_KEY__

# Database Configuration
DB_HOST=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=passwordmanager

# Application Settings
NODE_ENV=production
PORT=5000

# Security Settings
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Optional: SMTP (configure if you want email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Password Manager <noreply@example.com>
